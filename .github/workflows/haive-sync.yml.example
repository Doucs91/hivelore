# Hivelore sync — example workflow
#
# Copy this file to .github/workflows/haive-sync.yml in YOUR project to keep
# memory anchors fresh after every merge to main/develop, and to comment on
# PRs when their changes would invalidate existing memories.
#
# Requires: Node 20+, @hivelore/cli installed (or via npx).

name: Hivelore sync

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

permissions:
  contents: read
  pull-requests: write

jobs:
  sync-on-merge:
    if: github.event_name == 'push'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Install Hivelore
        run: npm install -g @hivelore/cli
      - name: Refresh memory state
        run: |
          hivelore sync --since HEAD~1 || true
      - name: Commit updates if any
        run: |
          if [[ -n "$(git status --porcelain .ai/)" ]]; then
            git config user.name "haive-bot"
            git config user.email "haive-bot@users.noreply.github.com"
            git add .ai/
            git commit -m "chore(haive): refresh memory anchors"
            git push
          fi

  pr-impact:
    if: github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Install Hivelore
        run: npm install -g @hivelore/cli
      - name: Verify anchors that touch this PR
        id: verify
        run: |
          # Run verify (no --update so we just see the report) and capture output.
          hivelore memory verify --all --dir . > verify.txt 2>&1 || true
          echo "report<<EOF" >> $GITHUB_OUTPUT
          cat verify.txt >> $GITHUB_OUTPUT
          echo "EOF" >> $GITHUB_OUTPUT
      - name: Comment on PR
        if: contains(steps.verify.outputs.report, 'STALE')
        uses: actions/github-script@v7
        with:
          script: |
            const report = process.env.REPORT || '';
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `### Hivelore PR check\n\nSome memories anchored in this PR will become stale after merge:\n\n\`\`\`\n${report}\n\`\`\`\n\nUpdate or remove the affected memories before merging, or accept that \`hivelore sync\` will mark them stale on main.`,
            });
        env:
          REPORT: ${{ steps.verify.outputs.report }}

  pr-memory-check:
    if: github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: Doucs91/hivelore/packages/github-action@main
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          # post-if-empty: 'true'   # uncomment to always post (even when no memories found)
          # max-memories: '5'       # limit memories per file in the comment
