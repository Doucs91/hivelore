{
  "name": "@hiveai/mcp",
  "version": "0.3.2",
  "description": "hAIve MCP server — exposes memory + project context to any MCP-compatible AI client",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doucs91/hAIve.git",
    "directory": "packages/mcp"
  },
  "bugs": "https://github.com/Doucs91/hAIve/issues",
  "homepage": "https://github.com/Doucs91/hAIve#readme",
  "keywords": ["ai", "memory", "mcp", "haive", "model-context-protocol", "agent", "team"],
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "haive-mcp": "./dist/index.js"
  },
  "files": ["dist", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hiveai/core": "^0.2.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@hiveai/embeddings": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@hiveai/embeddings": {
      "optional": true
    }
  }
}
