{
  "name": "@hivelore/mcp",
  "version": "0.52.1",
  "description": "Hivelore MCP server - policy-aware briefing and memory tools for coding-agent harnesses",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doucs91/hivelore.git",
    "directory": "packages/mcp"
  },
  "bugs": "https://github.com/Doucs91/hivelore/issues",
  "homepage": "https://github.com/Doucs91/hivelore#readme",
  "keywords": [
    "ai",
    "enforcement",
    "policy",
    "context",
    "breadcrumbs",
    "memory",
    "mcp",
    "haive",
    "model-context-protocol",
    "agent",
    "team",
    "harness",
    "harness-engineering"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "hivelore-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "node ../../scripts/ensure-workspace-dists.mjs @hivelore/core @hivelore/embeddings && tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hivelore/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hivelore/embeddings": "workspace:*"
  },
  "peerDependencies": {
    "@hivelore/embeddings": "*"
  },
  "peerDependenciesMeta": {
    "@hivelore/embeddings": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@ast-grep/napi": "^0.44.1",
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-java": "^0.0.7",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/lang-rust": "^0.0.7"
  }
}
