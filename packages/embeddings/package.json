{
  "name": "@hiveai/embeddings",
  "version": "0.2.9",
  "description": "hAIve embeddings — local sentence embeddings via Transformers.js for semantic memory search",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doucs91/hAIve.git",
    "directory": "packages/embeddings"
  },
  "bugs": "https://github.com/Doucs91/hAIve/issues",
  "homepage": "https://github.com/Doucs91/hAIve#readme",
  "keywords": ["ai", "memory", "embeddings", "transformers", "semantic-search", "haive"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hiveai/core": "workspace:*",
    "@xenova/transformers": "^2.17.2"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}
