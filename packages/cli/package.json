{
  "name": "@hivelore/cli",
  "version": "0.34.0",
  "description": "Hivelore CLI - repo-native memory and context policy for coding-agent harnesses",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doucs91/hivelore.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/Doucs91/hivelore/issues",
  "homepage": "https://github.com/Doucs91/hivelore#readme",
  "keywords": [
    "ai",
    "enforcement",
    "policy",
    "context",
    "breadcrumbs",
    "memory",
    "mcp",
    "haive",
    "agent",
    "team",
    "harness",
    "harness-engineering",
    "cli",
    "ci"
  ],
  "type": "module",
  "bin": {
    "hivelore": "./dist/index.js",
    "haive": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "node ../../scripts/ensure-workspace-dists.mjs @hivelore/core @hivelore/embeddings @hivelore/mcp && tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hivelore/core": "workspace:*",
    "@hivelore/embeddings": "workspace:*",
    "@hivelore/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "ink": "^7.0.1",
    "picocolors": "^1.1.1",
    "react": "^19.2.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
