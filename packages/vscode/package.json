{
  "name": "hivelore-vscode",
  "displayName": "Hivelore \u2014 Agent Harness & Context Enforcement",
  "description": "Repo-native context policy for coding-agent harnesses: surface decisions, gotchas, skills, and harness health inline.",
  "version": "0.6.3",
  "publisher": "hivelore",
  "icon": "media/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Doucs91/hivelore.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "enforcement",
    "policy",
    "context",
    "mcp",
    "harness",
    "cursor",
    "copilot",
    "knowledge",
    "skills"
  ],
  "activationEvents": [
    "workspaceContains:.ai/memories/**",
    "workspaceContains:.ai/haive.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hivelore-explorer",
          "title": "Hivelore",
          "icon": "media/logo-mono.svg"
        }
      ]
    },
    "views": {
      "hivelore-explorer": [
        {
          "id": "hivelore.memoriesView",
          "name": "Context Policy",
          "icon": "$(book)",
          "contextualTitle": "Context records"
        },
        {
          "id": "hivelore.cockpitView",
          "name": "Strategic Cockpit",
          "icon": "$(dashboard)",
          "contextualTitle": "Hivelore observability cockpit"
        },
        {
          "id": "hivelore.inboxView",
          "name": "Discipline Inbox",
          "icon": "$(checklist)",
          "contextualTitle": "Context hygiene actions"
        },
        {
          "id": "hivelore.harnessView",
          "name": "Harness Health",
          "icon": "$(pulse)",
          "contextualTitle": "Harness health scores"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hivelore.memoriesView",
        "contents": "No Hivelore context records found in this workspace.\n\nRun `hivelore init` to initialize Hivelore in your project.\n[Learn more](https://github.com/Doucs91/hivelore)\n\n[Initialize Hivelore](command:hivelore.init)"
      },
      {
        "view": "hivelore.cockpitView",
        "contents": "Run a strategic Hivelore check to see corpus health, eval quality, sensors, impact, usage, and risks.\n\n[Refresh Observability](command:hivelore.refreshObservability)"
      },
      {
        "view": "hivelore.inboxView",
        "contents": "Build the discipline inbox to review stale, pending, noisy, low-value, and sensor-related context work.\n\n[Refresh Observability](command:hivelore.refreshObservability)"
      },
      {
        "view": "hivelore.harnessView",
        "contents": "Run a harness health check to see doctor scores.\n\n[Run Health Check](command:hivelore.runDoctor)"
      }
    ],
    "commands": [
      {
        "command": "hivelore.refreshMemories",
        "title": "Hivelore: Refresh Memories",
        "icon": "$(refresh)"
      },
      {
        "command": "hivelore.showMemoriesForFile",
        "title": "Hivelore: Show Memories for This File"
      },
      {
        "command": "hivelore.showAllMemories",
        "title": "Hivelore: Show All Memories",
        "icon": "$(list-unordered)"
      },
      {
        "command": "hivelore.openMemory",
        "title": "Hivelore: Open Memory File"
      },
      {
        "command": "hivelore.addMemory",
        "title": "Hivelore: Add Memory\u2026",
        "icon": "$(add)"
      },
      {
        "command": "hivelore.copyMemoryBody",
        "title": "Hivelore: Copy Memory Content",
        "icon": "$(copy)"
      },
      {
        "command": "hivelore.searchMemories",
        "title": "Hivelore: Search Memories\u2026",
        "icon": "$(search)"
      },
      {
        "command": "hivelore.memTried",
        "title": "Hivelore: Record Failed Attempt\u2026",
        "icon": "$(debug-restart)"
      },
      {
        "command": "hivelore.runBriefing",
        "title": "Hivelore: Get Briefing for This File",
        "icon": "$(book)"
      },
      {
        "command": "hivelore.runDoctor",
        "title": "Hivelore: Run Health Check",
        "icon": "$(pulse)"
      },
      {
        "command": "hivelore.refreshObservability",
        "title": "Hivelore: Refresh Observability",
        "icon": "$(dashboard)"
      },
      {
        "command": "hivelore.runEval",
        "title": "Hivelore: Run Eval",
        "icon": "$(beaker)"
      },
      {
        "command": "hivelore.saveEvalBaseline",
        "title": "Hivelore: Save Eval Baseline",
        "icon": "$(bookmark)"
      },
      {
        "command": "hivelore.compareEval",
        "title": "Hivelore: Compare Eval to Baseline",
        "icon": "$(diff)"
      },
      {
        "command": "hivelore.runSensorsCheck",
        "title": "Hivelore: Run Sensors Check",
        "icon": "$(shield)"
      },
      {
        "command": "hivelore.runMemoryLint",
        "title": "Hivelore: Run Memory Lint",
        "icon": "$(wand)"
      },
      {
        "command": "hivelore.openMemoryById",
        "title": "Hivelore: Open Memory by ID"
      },
      {
        "command": "hivelore.runFixAction",
        "title": "Hivelore: Run Suggested Fix",
        "icon": "$(tools)"
      },
      {
        "command": "hivelore.markMemoryApplied",
        "title": "Hivelore: Mark Memory Applied",
        "icon": "$(check)"
      },
      {
        "command": "hivelore.markMemoryRejected",
        "title": "Hivelore: Mark Memory Rejected",
        "icon": "$(close)"
      },
      {
        "command": "hivelore.promoteSensor",
        "title": "Hivelore: Promote Sensor to Block",
        "icon": "$(shield)"
      },
      {
        "command": "hivelore.syncMemories",
        "title": "Hivelore: Sync Memories",
        "icon": "$(sync)"
      },
      {
        "command": "hivelore.approveMemory",
        "title": "Hivelore: Approve Memory",
        "icon": "$(pass)"
      },
      {
        "command": "hivelore.rejectMemory",
        "title": "Hivelore: Reject Memory",
        "icon": "$(trash)"
      },
      {
        "command": "hivelore.seedStackPack",
        "title": "Hivelore: Add Starter Memories (Stack Pack)\u2026",
        "icon": "$(sparkle)"
      },
      {
        "command": "hivelore.anchorMemory",
        "title": "Hivelore: Anchor Memory to File\u2026",
        "icon": "$(pin)"
      },
      {
        "command": "hivelore.promoteMemory",
        "title": "Hivelore: Promote Memory to Team",
        "icon": "$(arrow-up)"
      },
      {
        "command": "hivelore.init",
        "title": "Hivelore: Initialize in This Workspace"
      },
      {
        "command": "hivelore.showOutput",
        "title": "Hivelore: Show Output"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hivelore.addMemory",
          "when": "view == hivelore.memoriesView",
          "group": "navigation@1"
        },
        {
          "command": "hivelore.seedStackPack",
          "when": "view == hivelore.memoriesView",
          "group": "navigation@2"
        },
        {
          "command": "hivelore.searchMemories",
          "when": "view == hivelore.memoriesView",
          "group": "navigation@3"
        },
        {
          "command": "hivelore.refreshMemories",
          "when": "view == hivelore.memoriesView",
          "group": "navigation@4"
        },
        {
          "command": "hivelore.runDoctor",
          "when": "view == hivelore.harnessView",
          "group": "navigation@1"
        },
        {
          "command": "hivelore.refreshObservability",
          "when": "view == hivelore.cockpitView",
          "group": "navigation@1"
        },
        {
          "command": "hivelore.runEval",
          "when": "view == hivelore.cockpitView",
          "group": "navigation@2"
        },
        {
          "command": "hivelore.compareEval",
          "when": "view == hivelore.cockpitView",
          "group": "navigation@3"
        },
        {
          "command": "hivelore.refreshObservability",
          "when": "view == hivelore.inboxView",
          "group": "navigation@1"
        },
        {
          "command": "hivelore.runMemoryLint",
          "when": "view == hivelore.inboxView",
          "group": "navigation@2"
        },
        {
          "command": "hivelore.runSensorsCheck",
          "when": "view == hivelore.inboxView",
          "group": "navigation@3"
        },
        {
          "command": "hivelore.syncMemories",
          "when": "view == hivelore.harnessView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hivelore.anchorMemory",
          "when": "view == hivelore.memoriesView && viewItem == seedMemory",
          "group": "inline@0"
        },
        {
          "command": "hivelore.openMemory",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "inline@1"
        },
        {
          "command": "hivelore.copyMemoryBody",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "inline@2"
        },
        {
          "command": "hivelore.anchorMemory",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@1"
        },
        {
          "command": "hivelore.promoteMemory",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@2"
        },
        {
          "command": "hivelore.approveMemory",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@3"
        },
        {
          "command": "hivelore.rejectMemory",
          "when": "view == hivelore.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@4"
        },
        {
          "command": "hivelore.openMemoryById",
          "when": "viewItem == haiveMemoryAction || viewItem == haiveMemoryFeedbackAction || viewItem == haiveSensorAction",
          "group": "inline@1"
        },
        {
          "command": "hivelore.markMemoryApplied",
          "when": "viewItem == haiveMemoryFeedbackAction || viewItem == haiveMemoryAction",
          "group": "inline@2"
        },
        {
          "command": "hivelore.markMemoryRejected",
          "when": "viewItem == haiveMemoryFeedbackAction || viewItem == haiveMemoryAction",
          "group": "inline@3"
        },
        {
          "command": "hivelore.promoteSensor",
          "when": "viewItem == haiveSensorAction",
          "group": "inline@4"
        },
        {
          "command": "hivelore.runFixAction",
          "when": "viewItem == haiveFixAction",
          "group": "inline@5"
        },
        {
          "command": "hivelore.approveMemory",
          "when": "viewItem == haiveMemoryAction",
          "group": "haive@1"
        },
        {
          "command": "hivelore.rejectMemory",
          "when": "viewItem == haiveMemoryAction",
          "group": "haive@2"
        }
      ],
      "editor/title": [
        {
          "command": "hivelore.runBriefing",
          "when": "resourceScheme == file",
          "group": "haive"
        }
      ],
      "editor/context": [
        {
          "command": "hivelore.showMemoriesForFile",
          "group": "haive@1",
          "when": "resourceScheme == file"
        },
        {
          "command": "hivelore.runBriefing",
          "group": "haive@2",
          "when": "resourceScheme == file"
        },
        {
          "command": "hivelore.memTried",
          "group": "haive@3",
          "when": "resourceScheme == file"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hivelore.searchMemories",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "hivelore.runBriefing",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "Hivelore",
      "properties": {
        "hivelore.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline context record count (CodeLens) at the top of files with anchored Hivelore records."
        },
        "hivelore.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Hivelore memory count in the status bar."
        },
        "hivelore.memoriesDir": {
          "type": "string",
          "default": ".ai/memories",
          "description": "Path to the Hivelore context records directory relative to the workspace root."
        },
        "hivelore.highlightActionRequired": {
          "type": "boolean",
          "default": true,
          "description": "Highlight files with action_required Hivelore context records using a warning decoration."
        },
        "hivelore.cliPath": {
          "type": "string",
          "default": "haive",
          "description": "Path to the haive CLI binary. Use an absolute path if haive is not on PATH (e.g. /usr/local/bin/haive)."
        },
        "hivelore.briefingBudget": {
          "type": "string",
          "enum": [
            "default",
            "deep",
            "minimal"
          ],
          "default": "default",
          "description": "Token budget for hivelore briefing. Use 'deep' for a more thorough briefing at the cost of more tokens."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --external vscode --no-splitting",
    "watch": "tsup src/extension.ts --format cjs --out-dir dist --external vscode --no-splitting --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "@vscode/vsce": "^2.22.0"
  }
}
