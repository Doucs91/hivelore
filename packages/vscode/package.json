{
  "name": "haive-vscode",
  "displayName": "hAIve — Agent Harness & Context Enforcement",
  "description": "Repo-native context policy for coding-agent harnesses: surface decisions, gotchas, skills, and harness health inline.",
  "version": "0.6.3",
  "publisher": "hiveai",
  "icon": "media/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Doucs91/hAIve.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "AI", "Programming Languages"],
  "keywords": ["ai", "enforcement", "policy", "context", "mcp", "harness", "cursor", "copilot", "knowledge", "skills"],
  "activationEvents": [
    "workspaceContains:.ai/memories/**",
    "workspaceContains:.ai/haive.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "haive-explorer",
          "title": "hAIve",
          "icon": "media/logo-mono.svg"
        }
      ]
    },
    "views": {
      "haive-explorer": [
        {
          "id": "haive.memoriesView",
          "name": "Context Policy",
          "icon": "$(book)",
          "contextualTitle": "Context records"
        },
        {
          "id": "haive.cockpitView",
          "name": "Strategic Cockpit",
          "icon": "$(dashboard)",
          "contextualTitle": "hAIve observability cockpit"
        },
        {
          "id": "haive.inboxView",
          "name": "Discipline Inbox",
          "icon": "$(checklist)",
          "contextualTitle": "Context hygiene actions"
        },
        {
          "id": "haive.harnessView",
          "name": "Harness Health",
          "icon": "$(pulse)",
          "contextualTitle": "Harness health scores"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "haive.memoriesView",
        "contents": "No hAIve context records found in this workspace.\n\nRun `haive init` to initialize hAIve in your project.\n[Learn more](https://github.com/Doucs91/hAIve)\n\n[Initialize hAIve](command:haive.init)"
      },
      {
        "view": "haive.cockpitView",
        "contents": "Run a strategic hAIve check to see corpus health, eval quality, sensors, impact, usage, and risks.\n\n[Refresh Observability](command:haive.refreshObservability)"
      },
      {
        "view": "haive.inboxView",
        "contents": "Build the discipline inbox to review stale, pending, noisy, low-value, and sensor-related context work.\n\n[Refresh Observability](command:haive.refreshObservability)"
      },
      {
        "view": "haive.harnessView",
        "contents": "Run a harness health check to see doctor scores.\n\n[Run Health Check](command:haive.runDoctor)"
      }
    ],
    "commands": [
      {
        "command": "haive.refreshMemories",
        "title": "hAIve: Refresh Memories",
        "icon": "$(refresh)"
      },
      {
        "command": "haive.showMemoriesForFile",
        "title": "hAIve: Show Memories for This File"
      },
      {
        "command": "haive.showAllMemories",
        "title": "hAIve: Show All Memories",
        "icon": "$(list-unordered)"
      },
      {
        "command": "haive.openMemory",
        "title": "hAIve: Open Memory File"
      },
      {
        "command": "haive.addMemory",
        "title": "hAIve: Add Memory…",
        "icon": "$(add)"
      },
      {
        "command": "haive.copyMemoryBody",
        "title": "hAIve: Copy Memory Content",
        "icon": "$(copy)"
      },
      {
        "command": "haive.searchMemories",
        "title": "hAIve: Search Memories…",
        "icon": "$(search)"
      },
      {
        "command": "haive.memTried",
        "title": "hAIve: Record Failed Attempt…",
        "icon": "$(debug-restart)"
      },
      {
        "command": "haive.runBriefing",
        "title": "hAIve: Get Briefing for This File",
        "icon": "$(book)"
      },
      {
        "command": "haive.runDoctor",
        "title": "hAIve: Run Health Check",
        "icon": "$(pulse)"
      },
      {
        "command": "haive.refreshObservability",
        "title": "hAIve: Refresh Observability",
        "icon": "$(dashboard)"
      },
      {
        "command": "haive.runEval",
        "title": "hAIve: Run Eval",
        "icon": "$(beaker)"
      },
      {
        "command": "haive.saveEvalBaseline",
        "title": "hAIve: Save Eval Baseline",
        "icon": "$(bookmark)"
      },
      {
        "command": "haive.compareEval",
        "title": "hAIve: Compare Eval to Baseline",
        "icon": "$(diff)"
      },
      {
        "command": "haive.runSensorsCheck",
        "title": "hAIve: Run Sensors Check",
        "icon": "$(shield)"
      },
      {
        "command": "haive.runMemoryLint",
        "title": "hAIve: Run Memory Lint",
        "icon": "$(wand)"
      },
      {
        "command": "haive.openMemoryById",
        "title": "hAIve: Open Memory by ID"
      },
      {
        "command": "haive.runFixAction",
        "title": "hAIve: Run Suggested Fix",
        "icon": "$(tools)"
      },
      {
        "command": "haive.markMemoryApplied",
        "title": "hAIve: Mark Memory Applied",
        "icon": "$(check)"
      },
      {
        "command": "haive.markMemoryRejected",
        "title": "hAIve: Mark Memory Rejected",
        "icon": "$(close)"
      },
      {
        "command": "haive.promoteSensor",
        "title": "hAIve: Promote Sensor to Block",
        "icon": "$(shield)"
      },
      {
        "command": "haive.syncMemories",
        "title": "hAIve: Sync Memories",
        "icon": "$(sync)"
      },
      {
        "command": "haive.approveMemory",
        "title": "hAIve: Approve Memory",
        "icon": "$(pass)"
      },
      {
        "command": "haive.rejectMemory",
        "title": "hAIve: Reject Memory",
        "icon": "$(trash)"
      },
      {
        "command": "haive.seedStackPack",
        "title": "hAIve: Add Starter Memories (Stack Pack)…",
        "icon": "$(sparkle)"
      },
      {
        "command": "haive.anchorMemory",
        "title": "hAIve: Anchor Memory to File…",
        "icon": "$(pin)"
      },
      {
        "command": "haive.promoteMemory",
        "title": "hAIve: Promote Memory to Team",
        "icon": "$(arrow-up)"
      },
      {
        "command": "haive.init",
        "title": "hAIve: Initialize in This Workspace"
      },
      {
        "command": "haive.showOutput",
        "title": "hAIve: Show Output"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "haive.addMemory",
          "when": "view == haive.memoriesView",
          "group": "navigation@1"
        },
        {
          "command": "haive.seedStackPack",
          "when": "view == haive.memoriesView",
          "group": "navigation@2"
        },
        {
          "command": "haive.searchMemories",
          "when": "view == haive.memoriesView",
          "group": "navigation@3"
        },
        {
          "command": "haive.refreshMemories",
          "when": "view == haive.memoriesView",
          "group": "navigation@4"
        },
        {
          "command": "haive.runDoctor",
          "when": "view == haive.harnessView",
          "group": "navigation@1"
        },
        {
          "command": "haive.refreshObservability",
          "when": "view == haive.cockpitView",
          "group": "navigation@1"
        },
        {
          "command": "haive.runEval",
          "when": "view == haive.cockpitView",
          "group": "navigation@2"
        },
        {
          "command": "haive.compareEval",
          "when": "view == haive.cockpitView",
          "group": "navigation@3"
        },
        {
          "command": "haive.refreshObservability",
          "when": "view == haive.inboxView",
          "group": "navigation@1"
        },
        {
          "command": "haive.runMemoryLint",
          "when": "view == haive.inboxView",
          "group": "navigation@2"
        },
        {
          "command": "haive.runSensorsCheck",
          "when": "view == haive.inboxView",
          "group": "navigation@3"
        },
        {
          "command": "haive.syncMemories",
          "when": "view == haive.harnessView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "haive.anchorMemory",
          "when": "view == haive.memoriesView && viewItem == seedMemory",
          "group": "inline@0"
        },
        {
          "command": "haive.openMemory",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "inline@1"
        },
        {
          "command": "haive.copyMemoryBody",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "inline@2"
        },
        {
          "command": "haive.anchorMemory",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@1"
        },
        {
          "command": "haive.promoteMemory",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@2"
        },
        {
          "command": "haive.approveMemory",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@3"
        },
        {
          "command": "haive.rejectMemory",
          "when": "view == haive.memoriesView && (viewItem == memory || viewItem == seedMemory)",
          "group": "haive@4"
        },
        {
          "command": "haive.openMemoryById",
          "when": "viewItem == haiveMemoryAction || viewItem == haiveMemoryFeedbackAction || viewItem == haiveSensorAction",
          "group": "inline@1"
        },
        {
          "command": "haive.markMemoryApplied",
          "when": "viewItem == haiveMemoryFeedbackAction || viewItem == haiveMemoryAction",
          "group": "inline@2"
        },
        {
          "command": "haive.markMemoryRejected",
          "when": "viewItem == haiveMemoryFeedbackAction || viewItem == haiveMemoryAction",
          "group": "inline@3"
        },
        {
          "command": "haive.promoteSensor",
          "when": "viewItem == haiveSensorAction",
          "group": "inline@4"
        },
        {
          "command": "haive.runFixAction",
          "when": "viewItem == haiveFixAction",
          "group": "inline@5"
        },
        {
          "command": "haive.approveMemory",
          "when": "viewItem == haiveMemoryAction",
          "group": "haive@1"
        },
        {
          "command": "haive.rejectMemory",
          "when": "viewItem == haiveMemoryAction",
          "group": "haive@2"
        }
      ],
      "editor/title": [
        {
          "command": "haive.runBriefing",
          "when": "resourceScheme == file",
          "group": "haive"
        }
      ],
      "editor/context": [
        {
          "command": "haive.showMemoriesForFile",
          "group": "haive@1",
          "when": "resourceScheme == file"
        },
        {
          "command": "haive.runBriefing",
          "group": "haive@2",
          "when": "resourceScheme == file"
        },
        {
          "command": "haive.memTried",
          "group": "haive@3",
          "when": "resourceScheme == file"
        }
      ]
    },
    "keybindings": [
      {
        "command": "haive.searchMemories",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "haive.runBriefing",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "hAIve",
      "properties": {
        "haive.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline context record count (CodeLens) at the top of files with anchored hAIve records."
        },
        "haive.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the hAIve memory count in the status bar."
        },
        "haive.memoriesDir": {
          "type": "string",
          "default": ".ai/memories",
          "description": "Path to the hAIve context records directory relative to the workspace root."
        },
        "haive.highlightActionRequired": {
          "type": "boolean",
          "default": true,
          "description": "Highlight files with action_required hAIve context records using a warning decoration."
        },
        "haive.cliPath": {
          "type": "string",
          "default": "haive",
          "description": "Path to the haive CLI binary. Use an absolute path if haive is not on PATH (e.g. /usr/local/bin/haive)."
        },
        "haive.briefingBudget": {
          "type": "string",
          "enum": ["default", "deep", "minimal"],
          "default": "default",
          "description": "Token budget for haive briefing. Use 'deep' for a more thorough briefing at the cost of more tokens."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --external vscode --no-splitting",
    "watch": "tsup src/extension.ts --format cjs --out-dir dist --external vscode --no-splitting --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "@vscode/vsce": "^2.22.0"
  }
}
