# Copy to sonar-mcp.local.env (not versioned):
#   cp sonar-mcp.local.env.example sonar-mcp.local.env

# Public URL for your SonarQube Server instance
SONARQUBE_URL=https://sonarqube.example.com

# User token (My Account > Security in SonarQube), not a project/global token
SONARQUBE_TOKEN=

# Optional: same key as sonar-project.properties (fewer parameters in MCP tools)
SONARQUBE_PROJECT_KEY=haive

# Optional: restrict toolsets to reduce MCP context
# SONARQUBE_TOOLSETS=issues,quality-gates,measures,security-hotspots
