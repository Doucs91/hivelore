# Copier vers sonar-mcp.local.env (non versionné) :
#   cp sonar-mcp.local.env.example sonar-mcp.local.env

# URL publique de ton instance SonarQube Server
SONARQUBE_URL=https://sonarqube.example.com

# Token utilisateur (My Account > Security sur SonarQube) — pas un token projet/global
SONARQUBE_TOKEN=

# Optionnel : même clé que sonar-project.properties (moins de paramètres dans les outils MCP)
SONARQUBE_PROJECT_KEY=haive

# Optionnel : restreindre les toolsets pour alléger le contexte MCP
# SONARQUBE_TOOLSETS=issues,quality-gates,measures,security-hotspots
